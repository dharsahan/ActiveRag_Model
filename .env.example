# Neo4j Configuration
# These variables are used by both the docker-compose.neo4j.yml file and the test suite
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=activerag123

# Note: In production, use a strong password and consider using secrets management
# Example strong password: NEO4J_PASSWORD=your_secure_password_here_123!